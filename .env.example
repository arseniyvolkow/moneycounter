# ==================================
# Telegram Bot Configuration
# ==================================
# The token for your Telegram Bot (Get from @BotFather)
BOT_TOKEN=your_telegram_token
# URL of the Django backend API (Default: http://localhost:8000)
API_BASE_URL=http://localhost:8000
# Ngrok URL, cause telegram need https
WEBAPP_URL=https://your_url.com

# ==================================
# Django Core Configuration
# ==================================
# Security Key for Django (Make this unique and secret in production)
SECRET_KEY=django-insecure-your-secret-key-here
# Debug mode (Set to False in production)
DEBUG=True
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ==================================
# Database & Cache
# ==================================
# Database Connection URL
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://admin:pass@db:5432/finance_db

# Redis Connection URL
# Format: redis://host:port/db
REDIS_URL=redis://redis:6379/0

# ==================================
# AI Services Configuration
# ==================================
# URL for Ollama LLM service
OLLAMA_URL=http://ollama:11434
# URL for Whisper Speech-to-Text service
WHISPER_URL=http://whisper:9000/asr

# ==================================
# Docker Compose Variables (Optional)
# ==================================
# These are used by docker-compose.yml
POSTGRES_DB=finance_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=pass
